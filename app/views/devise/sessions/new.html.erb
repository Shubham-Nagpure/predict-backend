<h2 class="text-3xl font-bold text-center mb-6">Log in</h2>

<%= form_for(resource, as: resource_name, url: session_path(resource_name), class: "max-w-md mx-auto bg-white p-6 rounded-lg shadow-md") do |f| %>
  <div class="mb-4">
    <%= f.label :email, class: "block text-gray-700 font-medium mb-2" %>
    <%= f.email_field :email, autofocus: true, autocomplete: "email",
          class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" %>
  </div>

  <div class="mb-4">
    <%= f.label :password, class: "block text-gray-700 font-medium mb-2" %>
    <%= f.password_field :password, autocomplete: "current-password",
          class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" %>
  </div>

  <% if devise_mapping.rememberable? %>
    <div class="mb-4 flex items-center">
      <%= f.check_box :remember_me, class: "mr-2 rounded border-gray-300 focus:ring-blue-500" %>
      <%= f.label :remember_me, class: "text-gray-700 font-medium" %>
    </div>
  <% end %>

  <div class="mt-6">
    <%= f.submit "Log in", class: "w-full bg-blue-600 text-white py-2 rounded-lg hover:bg-blue-500 transition font-semibold" %>
  </div>
<% end %>

