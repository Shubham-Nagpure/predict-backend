<%= form_with(model: contest, class: "contents") do |form| %>
  <% if contest.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(contest.errors.count, "error") %> prohibited this contest from being saved:</h2>

      <ul class="list-disc ml-6">
        <% contest.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :title %>
    <%= form.text_field :title, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": contest.errors[:title].none?, "border-red-400 focus:outline-red-600": contest.errors[:title].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :description %>
    <%= form.text_field :description, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": contest.errors[:description].none?, "border-red-400 focus:outline-red-600": contest.errors[:description].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :name, "Select Name" %>
    <%= form.select :name, options_for_select(Contest::CONTEST_NAME.keys), { prompt: "Choose a name" },
      class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full",
              {"border-gray-400 focus:outline-blue-600": contest.errors[:name].none?}]
    %>
  </div>

  <div class="my-5">
    <%= form.label :contest_type, "Select Type" %>
    <%= form.select :contest_type, options_for_select(Contest::CONTEST_TYPE.keys), { prompt: "Choose a team" },
      class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full",
              {"border-gray-400 focus:outline-blue-600": contest.errors[:contest_type].none?}]
    %>
  </div>

  <div class="my-5">
    <%= form.label :status, "Select Status" %>
    <%= form.select :status, options_for_select(Contest::STATUS.keys), { prompt: "Choose a status" },
      class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full",
              {"border-gray-400 focus:outline-blue-600": contest.errors[:status].none?}]
    %>
  </div>

  <div class="my-5">
    <%= form.label :match_id, "Select Match" %>
    <%= form.collection_select :match_id, Match.all, :id, :title,
      { prompt: "Choose a team" },
      class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full",
              {"border-gray-400 focus:outline-blue-600": contest.errors[:match_id].none?,
               "border-red-400 focus:outline-red-600": contest.errors[:match_id].any?}]
    %>
  </div>

  <div class="my-5">
    <%= form.label :start_time %>
    <%= form.datetime_field :start_time, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": contest.errors[:start_time].none?, "border-red-400 focus:outline-red-600": contest.errors[:start_time].any?}] %>
  </div>

  <div class="inline">
    <%= form.submit class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  </div>
<% end %>
