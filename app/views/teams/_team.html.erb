<div id="<%= dom_id team %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Name:</strong>
    <%= team.name %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Logo:</strong>

    <% if team.logo.attached? %>
      <%= image_tag team.logo_url, width: "150px", height: "150px" %>
    <% end %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Captain:</strong>
    <%= team.captain_id %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Team size:</strong>
    <%= team.team_size %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Deleted at:</strong>
    <%= team.deleted_at %>
  </div>
</div>
