<div id="<%= dom_id match %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Title:</strong>
    <%= match.title %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Team one:</strong>
    <%= match.team_one_id %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Team two:</strong>
    <%= match.team_two_id %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Timing:</strong>
    <%= match.timing %>
  </div>
</div>
