<div id="<%= dom_id user %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Emp:</strong>
    <%= user.emp_id %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Email:</strong>
    <%= user.email %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Username:</strong>
    <%= user.username %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Role:</strong>
    <%= user.role_id %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Deleted at:</strong>
    <%= user.deleted_at %>
  </div>
</div>
