<%= form_with(model: @contest_result, class: "content_results", url: url) do |form| %>
  <%= form.hidden_field :contest_id, value: params[:contest_id]%>

  <% if contest_result.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(contest_result.errors.count, "error") %> prohibited this contest_result from being saved:</h2>

      <ul class="list-disc ml-6">
        <% contest_result.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :team_id, "Select Winner" %>
    <%= form.collection_select :team_id, Contest.find_by(id: params[:contest_id]).match.teams, :id, :name,
      { prompt: "Choose a team" },
      class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full",
              {"border-gray-400 focus:outline-blue-600": contest_result.errors[:team_id].none?,
               "border-red-400 focus:outline-red-600": contest_result.errors[:team_id].any?}]
    %>
  </div>

  <div class="inline">
    <%= form.submit class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  </div>
<% end %>
